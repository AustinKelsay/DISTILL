{
  "name": "distill",
  "version": "0.1.0",
  "description": "Local-first conversation collector for Codex CLI and Claude Code",
  "main": "dist/electron/main.js",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "npm run build && env -u ELECTRON_RUN_AS_NODE electron .",
    "doctor": "npm run build && node dist/cli/doctor.js",
    "import": "npm run build && node dist/cli/import.js",
    "export": "npm run build && node dist/cli/export.js",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "electron": "^41.0.4",
    "typescript": "^6.0.2"
  }
}
