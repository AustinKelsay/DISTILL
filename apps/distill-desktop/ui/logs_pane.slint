import { HorizontalBox, ListView, TextEdit } from "std-widgets.slint";
import { LaneChip, LogCard, LogRowData, SectionHeader, ToneChip } from "components.slint";

export global LogsStore {
    in property <[LogRowData]> log_rows;
    in property <string> logs_empty_title;
    in property <string> logs_empty_message;
    in property <string> log_detail_title;
    in property <string> log_detail_status;
    in property <string> log_detail_summary;
    in property <string> log_detail_metrics;
    in property <string> log_detail_raw_json;
    in property <string> log_detail_empty_message;
    in property <int> active_log_filter: 0;

    callback logs_filter_selected(int);
    callback log_selected(int);
    callback adjust_logs_width(int);
}

export component LogsPane inherits Rectangle {
    in property <length> list_width: 420px;

    background: transparent;

    Rectangle {
        width: root.list_width;
        height: parent.height;
        background: #ffffff;
        border-radius: 24px;
        border-width: 1px;
        border-color: #dde4f0;

        SectionHeader {
            x: 18px;
            y: 16px;
            width: parent.width - 36px;
            title: "Logs";
            subtitle: "Sync and export history rendered from the existing Distill data.";
            show_resize: true;
            decrease => { LogsStore.adjust_logs_width(-40); }
            increase => { LogsStore.adjust_logs_width(40); }
        }

        HorizontalBox {
            x: 18px;
            y: 82px;
            width: parent.width - 36px;
            height: 34px;
            spacing: 8px;

            for label[index] in ["All", "Sync", "Exports", "Errors"] : LaneChip {
                label: label;
                selected: LogsStore.active_log_filter == index;
                clicked => { LogsStore.logs_filter_selected(index); }
            }
        }

        ListView {
            x: 18px;
            y: 128px;
            width: parent.width - 36px;
            height: parent.height - 146px;

            for row[index] in LogsStore.log_rows : LogCard {
                item: row;
                item_index: index;
                clicked(index) => { LogsStore.log_selected(index); }
            }
        }

        if LogsStore.log_rows.length == 0 : Rectangle {
            x: 18px;
            y: 140px;
            width: parent.width - 36px;
            height: 84px;
            background: transparent;

            Text {
                width: parent.width;
                text: LogsStore.logs_empty_title + "\n" + LogsStore.logs_empty_message;
                color: #70788b;
                font-size: 12px;
            }
        }
    }

    Rectangle {
        x: root.list_width + 16px;
        width: parent.width - root.list_width - 16px;
        height: parent.height;
        background: #ffffff;
        border-radius: 24px;
        border-width: 1px;
        border-color: #dde4f0;

        SectionHeader {
            x: 18px;
            y: 16px;
            width: parent.width - 36px;
            title: LogsStore.log_detail_title == "" ? "Log Detail" : LogsStore.log_detail_title;
            subtitle: LogsStore.log_detail_summary;
        }

        HorizontalBox {
            x: 18px;
            y: 82px;
            width: parent.width - 36px;
            height: 28px;
            spacing: 8px;

            ToneChip { text: LogsStore.log_detail_status; }
            ToneChip { text: LogsStore.log_detail_metrics; }
        }

        Rectangle {
            x: 18px;
            y: 126px;
            width: parent.width - 36px;
            height: parent.height - 144px;
            background: #fafbfd;
            border-radius: 18px;
            border-width: 1px;
            border-color: #e5eaf4;

            Text {
                x: 14px;
                y: 14px;
                text: "Raw JSON";
                font-size: 13px;
                font-weight: 600;
                color: #1f2430;
            }

            TextEdit {
                x: 14px;
                y: 40px;
                width: parent.width - 28px;
                height: parent.height - 54px;
                text: LogsStore.log_detail_raw_json == "" ? LogsStore.log_detail_empty_message : LogsStore.log_detail_raw_json;
                read-only: true;
            }
        }
    }
}
